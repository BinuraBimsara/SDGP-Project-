rules_version = '2';

// Firebase Storage Security Rules for SpotIT Community Reporting App
// 
// Folder Structure: reports/{reportID}/{filename}
// 
// Access Control:
// - Read (view): Anyone can view uploaded evidence files
// - Write (upload): Only authenticated users can upload files
// - Delete: Only the original reporter or government officials can delete files

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is a government official
    // Officials are identified by having a .gov email domain ending
    // or by having the 'official' custom claim set to true
    function isOfficial() {
      return isAuthenticated() && (
        request.auth.token.email.matches('.*@.*\\.gov$') ||
        request.auth.token.official == true
      );
    }
    
    // Helper function to check if the user is the owner of the file
    // based on the 'reporterUid' custom metadata
    function isReportOwner() {
      return isAuthenticated() && (
        resource.metadata.reporterUid == request.auth.uid
      );
    }
    
    // Helper function to validate image file
    function isValidImage() {
      return request.resource.contentType.matches('image/.*')
             && request.resource.size < 10 * 1024 * 1024; // Max 10MB
    }
    
    // Helper function to validate video file
    function isValidVideo() {
      return request.resource.contentType.matches('video/.*')
             && request.resource.size < 50 * 1024 * 1024; // Max 50MB
    }
    
    // Helper function to validate media file (image or video)
    function isValidMedia() {
      return isValidImage() || isValidVideo();
    }
    
    // Rules for report evidence files
    // Path: reports/{reportId}/{fileName}
    match /reports/{reportId}/{fileName} {
      
      // ALLOW READ: Anyone can view evidence files
      // This enables citizens to see photos of reported issues
      allow read: if true;
      
      // ALLOW CREATE: Authenticated users can upload evidence
      // Files must be valid media files (images or videos)
      allow create: if isAuthenticated() && isValidMedia();
      
      // ALLOW UPDATE: Only file owner or officials can update metadata
      allow update: if isReportOwner() || isOfficial();
      
      // ALLOW DELETE: Only the original reporter or government officials
      // can delete evidence files
      allow delete: if isReportOwner() || isOfficial();
    }
    
    // Rules for user profile images
    // Path: users/{userId}/profile/{fileName}
    match /users/{userId}/profile/{fileName} {
      
      // Anyone can view profile images
      allow read: if true;
      
      // Users can only upload their own profile images
      allow create, update: if isAuthenticated() 
                            && request.auth.uid == userId
                            && isValidImage();
      
      // Users can only delete their own profile images
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Default: Deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
